{
    "name": "kaliop/image-bundle",
    "description": "A set of tools for managing images in Ibexa.",
    "keywords": [
        "ibexa",
        "symfony",
        "symfony-bundle",
        "image",
        "webp",
        "focal-point",
        "responsive-images"
    ],
    "homepage": "https://github.com/kaliop/image-bundle",
    "type": "symfony-bundle",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Stanislaw Klimaszewski",
            "email": "sklimaszewski@kaliop.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Kaliop\\Image\\": "src/lib/",
            "Kaliop\\Bundle\\Image\\": "src/bundle/"
        }
    },
    "require": {
        "php": ">=8.3",
        "ext-fileinfo": "*",
        "ext-dom": "*",
        "ibexa/core": "~5.0.0",
        "ibexa/admin-ui": "~5.0.0",
        "nyholm/psr7": "^1.8",
        "guzzlehttp/promises": "^2.5"
    },
    "require-dev": {
        "ibexa/code-style": "~2.3.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "qossmic/deptrac-shim": "^0.24.0 || ^1.0.2"
    },
    "conflict": {
        "kaliop/ibexawebpbundle": "*"
    },
    "scripts": {
        "fix-cs": "php-cs-fixer fix --config=.php-cs-fixer.php --show-progress=dots",
        "check-cs": "@fix-cs --dry-run",
        "phpstan": "phpstan analyse -c phpstan.neon --memory-limit=2G",
        "deptrac": "php vendor/bin/deptrac analyse"
    },
    "scripts-descriptions": {
        "fix-cs": "Automatically fixes code style in all files",
        "check-cs": "Run code style checker for all files",
        "phpstan": "Run static code analysis",
        "deptrac": "Run Deptrac architecture testing"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "support": {
        "issues": "https://github.com/kaliop/image-bundle/issues",
        "source": "https://github.com/kaliop/image-bundle",
        "docs": "https://github.com/kaliop/image-bundle#readme"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    }
}
